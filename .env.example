# RoadVision AI — variáveis de ambiente
# Copie para .env (local) ou configure em Vercel → Project Settings → Environment Variables
# Variáveis VITE_* são embutidas no build — alterações na Vercel exigem redeploy.

# ── Obrigatória ───────────────────────────────────────────────────────────

# URL do Hugging Face Space (sem barra no final, sem /predict)
VITE_API_BASE_URL=https://inelialmeida-roadsign-detection-yl.hf.space

# ── Opcional ──────────────────────────────────────────────────────────────

# Tamanho de inferência YOLO: 416 = CPU no HF Space · 640 = GPU
VITE_API_IMAGE_SIZE=416

# ── Vercel: Project Settings → Environment Variables ──────────────────────
# Adicione estas variáveis em Production (e Preview, se quiser o mesmo backend).
# Variáveis VITE_* são embutidas no build — alterações exigem redeploy.

# URL do Hugging Face Space (sem barra no final, sem /predict)
VITE_API_BASE_URL=https://inelialmeida-roadsign-detection-yl.hf.space

# Tamanho de inferência YOLO (416 = CPU; 640 = GPU no HF Space)
VITE_API_IMAGE_SIZE=416

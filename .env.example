# RoadVision AI — template de variáveis (valores de exemplo, sem URL real)
# Copie para .env e substitua pelos seus valores:
#   cp .env.example .env
#
# Vercel: Project Settings → Environment Variables (Production + Preview)
# Variáveis VITE_* são embutidas no build — alterações exigem redeploy.

# ── Obrigatória ───────────────────────────────────────────────────────────

# URL do seu Hugging Face Space (sem barra no final, sem /predict)
VITE_API_BASE_URL=https://your-username-your-space.hf.space

# ── Opcional ──────────────────────────────────────────────────────────────

# Tamanho de inferência YOLO: 416 = CPU · 640 = GPU
VITE_API_IMAGE_SIZE=416
